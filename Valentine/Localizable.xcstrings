    "This program is free software: you can redistribute it and/or modify it under the terms of the GNU General Public License as published by the Free Software Foundation, either version 3 of the License, or (at your option) any later version." : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este programa es software libre: puedes redistribuirlo y/o modificarlo bajo los términos de la Licencia Pública General de GNU publicada por la Free Software Foundation, ya sea la versión 3 de la Licencia, o (a tu elección) cualquier versión posterior."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह प्रोग्राम मुफ़्त सॉफ़्टवेयर है: आप इसे फ्री सॉफ्टवेयर फाउंडेशन द्वारा प्रकाशित GNU जनरल पब्लिक लाइसेंस की शर्तों के तहत पुनर्वितरित और/या संशोधित कर सकते हैं, या तो लाइसेंस का संस्करण 3, या (आपके विकल्प पर) कोई भी बाद का संस्करण।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このプログラムはフリーソフトウェアです：Free Software Foundationが発行するGNU General Public Licenseの条件の下で、ライセンスのバージョン3、または（あなたの選択により）それ以降のバージョンのいずれかに従って、再頒布および/または変更することができます。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este programa é software livre: você pode redistribuí-lo e/ou modificá-lo sob os termos da Licença Pública Geral GNU conforme publicada pela Free Software Foundation, tanto a versão 3 da Licença, ou (a seu critério) qualquer versão posterior."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本程序是自由软件：您可以根据自由软件基金会发布的GNU通用公共许可证的条款重新分发和/或修改它，可以是许可证的第3版，或者（由您选择）任何更高版本。"
          }
        }
      }
    },
    "This project is and always will be open source, free, and ad-free. You can support the development by making a donation to maintain it over time!." : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este proyecto es y siempre será código abierto, libre y sin anuncios, puedes apoyar el desarrollo haciendo un donativo para mantener su desarrollo con el tiempo!."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह प्रोजेक्ट हमेशा ओपन सोर्स, मुफ़्त और विज्ञापन-मुक्त रहेगा। आप इसे समय के साथ बनाए रखने के लिए दान करके विकास का समर्थन कर सकते हैं!।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このプロジェクトは今後も常にオープンソース、無料、広告なしです。長期にわたる開発を維持するために、寄付による支援をお願いします！"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este projeto é e sempre será de código aberto, livre e sem anúncios, você pode apoiar o desenvolvimento fazendo uma doação para mantê-lo ao longo do tempo!."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此项目现在和将来都将是开源、免费且无广告的。您可以通过捐赠来支持开发，以随时间推移维护它！"
          }
        }
      }
